stack: -1,0:1:1
stack: 0,-1:2:1,2
stack: 0,0:1:1
stack: 1,-1:1:1
stack: 2,0:1:1
stack: 3,0:1:1

name: Exact Toll
desc: The bridge wants the exact value.
tip: Higher is not always better. A value gate requires the exact value shown.
radius: 2
side_a: Q_NEG
side_b: Q_POS
move_limit: 4
blocked: -1,1
blocked: 0,1
blocked: 2,-1
required: 0,0:2
